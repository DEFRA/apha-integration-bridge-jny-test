{
  "name": "apha-integration-bridge-jny-test",
  "version": "0.0.0",
  "type": "module",
  "description": "",
  "engines": {
    "node": ">=24.1.0"
  },
  "author": "Defra DDTS",
  "license": "OGL-UK-3.0",
  "aliases": {
    "~": ".",
    "page-objects": "test/page-objects",
    "components": "test/components"
  },
  "scripts": {
    "clean": "rm -rf allure-results && rm -rf allure-report && rm -f FAILED",
    "test": "npm run clean && npm run test:run",
    "test:run": "node ./bin/run-cucumber.mjs",
    "test:dev": "npm run clean && node ./bin/run-cucumber.mjs --env=dev",
    "test:test": "npm run clean && node ./bin/run-cucumber.mjs --env=test",
    "test:perf": "npm run clean && node ./bin/run-cucumber.mjs --env=perf-test",
    "test:prod": "npm run clean && node ./bin/run-cucumber.mjs --env=prod",
    "test:local": "npm run test",
    "test:github": "npm run test",
    "format": "prettier --write 'test/**/*.js' '**/*.{js,md,json,config.js}'",
    "format:check": "prettier --check 'test/**/*.js' '**/*.{js,md,json,config.js}'",
    "git:pre-commit-hook": "npm run format:check && npm run lint",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "postinstall": "npm run setup:husky",
    "setup:husky": "node -e \"try { (await import('husky')).default() } catch (e) { if (e.code !== 'ERR_MODULE_NOT_FOUND') throw e }\" --input-type module",
    "report": "node ./bin/generate-report.mjs",
    "report:publish": "npm run report && ./bin/publish-tests.sh"
  },
  "dependencies": {
    "@cucumber/cucumber": "13.0.0",
    "axios": "1.18.0",
    "chai": "6.2.2",
    "deepmerge": "4.3.1",
    "esm-module-alias": "2.2.1",
    "global-agent": "4.1.3",
    "undici": "8.3.0"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-config-standard": "17.1.0",
    "eslint-plugin-prettier": "5.5.6",
    "husky": "9.1.7",
    "prettier": "3.8.4"
  }
}
